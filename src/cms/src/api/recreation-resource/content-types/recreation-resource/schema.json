{
  "kind": "collectionType",
  "collectionName": "recreation_resources",
  "info": {
    "singularName": "recreation-resource",
    "pluralName": "recreation-resources",
    "displayName": "Recreation-resource"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "recResourceId": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "resourceName": {
      "type": "string",
      "required": true
    },
    "longitude": {
      "type": "decimal"
    },
    "latitude": {
      "type": "decimal"
    },
    "isDisplayed": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "recreationResourceType": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::recreation-resource-type.recreation-resource-type"
    },
    "recreationDistrict": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::recreation-district.recreation-district"
    },
    "recreationAdvisories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::recreation-advisory.recreation-advisory",
      "mappedBy": "recreationResources"
    }
  }
}
